\\src\\reducers\\attendanceReducer.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\components\\message.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\components\\loader.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\components\\formContainer.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\screens\\studentTableView.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\components\\student.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\actions\\userActions.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\actions\\attendanceActions.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\components\\analysisComponent.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\components\\attendanceTable.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\components\\paginate.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\components\\searchBox.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\constants\\studentConstant.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\constants\\userConstants.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\constants\\attendanceConstant.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\components\\attendanceTableComponent.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\components\\protectedRoute.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\components\\scrollToTop.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\screens\\StaffDashboard.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\screens\\AdminDashboard.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\screens\\StudentDashboard.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\screens\\StaffManagementScreen.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\screens\\ApprovalScreen.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\components\\customToast.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\screens\\MyAttendanceView.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\reducers\\notificationReducers.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\constants\\notificationConstants.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\actions\\notificationActions.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\screens\\NotificationScreen.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\screens\\BroadcastScreen.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\components\\broadcastForm.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\reducers\\grievanceReducers.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\constants\\grievanceConstants.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\screens\\GrievanceScreen.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\screens\\GrievanceAdminScreen.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\actions\\grievanceActions.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\reducers\\complaintReducers.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\constants\\complaintConstants.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\screens\\ComplaintScreen.jsx",["247"],"import React, { useState, useEffect } from \"react\";\nimport { Container, Row, Col, Form, Button, Card, Table, Badge, Modal } from \"react-bootstrap\";\nimport { useDispatch, useSelector } from \"react-redux\";\nimport { createComplaint, listMyComplaints } from \"../actions/complaintActions.jsx\";\nimport { COMPLAINT_CREATE_RESET } from \"../constants/complaintConstants.jsx\";\nimport Message from \"../components/message\";\nimport Loader from \"../components/loader\";\n\nconst ComplaintScreen = () => {\n  const [title, setTitle] = useState(\"\");\n  const [description, setDescription] = useState(\"\");\n  const [category, setCategory] = useState(\"Electrical\");\n  const [roomNo, setRoomNo] = useState(\"\");\n  const [image, setImage] = useState(\"\");\n  const [showModal, setShowModal] = useState(false);\n\n  const dispatch = useDispatch();\n\n  const complaintCreate = useSelector((state) => state.complaintCreate);\n  const { loading: loadingCreate, error: errorCreate, success: successCreate } = complaintCreate;\n\n  const complaintMyList = useSelector((state) => state.complaintMyList);\n  const { loading, error, complaints } = complaintMyList;\n\n  const userLogin = useSelector((state) => state.userLogin);\n  const { userInfo } = userLogin;\n\n  useEffect(() => {\n    if (successCreate) {\n      setShowModal(false);\n      setTitle(\"\");\n      setDescription(\"\");\n      setCategory(\"Electrical\");\n      setRoomNo(\"\");\n      setImage(\"\");\n      dispatch({ type: COMPLAINT_CREATE_RESET });\n      dispatch(listMyComplaints());\n    } else {\n      dispatch(listMyComplaints());\n    }\n  }, [dispatch, successCreate]);\n\n  const submitHandler = (e) => {\n    e.preventDefault();\n    dispatch(createComplaint({ title, description, category, roomNo, image }));\n  };\n\n  const getStatusBadge = (status) => {\n    switch (status) {\n      case \"Pending\": return <Badge variant=\"warning\">Pending</Badge>;\n      case \"In Progress\": return <Badge variant=\"info\">In Progress</Badge>;\n      case \"Resolved\": return <Badge variant=\"success\">Resolved</Badge>;\n      default: return <Badge variant=\"secondary\">{status}</Badge>;\n    }\n  };\n\n  return (\n    <Container className=\"py-4\">\n      <Row className=\"align-items-center mb-4\">\n        <Col>\n          <h2 className=\"font-weight-bold text-dark\">Complaints & Maintenance</h2>\n          <p className=\"text-muted\">Raise a ticket for any room or hostel maintenance issues.</p>\n        </Col>\n        <Col className=\"text-right\">\n          <Button variant=\"primary\" className=\"rounded-pill px-4 shadow-sm\" onClick={() => setShowModal(true)}>\n            <i className=\"fas fa-plus mr-2\"></i> New Complaint\n          </Button>\n        </Col>\n      </Row>\n\n      {loading ? (\n        <Loader />\n      ) : error ? (\n        <Message variant=\"danger\">{error}</Message>\n      ) : (\n        <Card className=\"border-0 shadow-sm rounded-lg overflow-hidden\">\n          <Table responsive hover className=\"mb-0\">\n            <thead className=\"bg-light\">\n              <tr>\n                <th>Date</th>\n                <th>Title</th>\n                <th>Category</th>\n                <th>Status</th>\n                <th>Admin Comment</th>\n              </tr>\n            </thead>\n            <tbody>\n              {complaints.map((c) => (\n                <tr key={c._id}>\n                  <td className=\"small text-muted\">{new Date(c.createdAt).toLocaleDateString()}</td>\n                  <td>\n                    <div className=\"font-weight-bold\">{c.title}</div>\n                    <div className=\"small text-muted text-truncate\" style={{ maxWidth: \"200px\" }}>{c.description}</div>\n                  </td>\n                  <td><Badge variant=\"light\" className=\"border\">{c.category}</Badge></td>\n                  <td>{getStatusBadge(c.status)}</td>\n                  <td className=\"small text-muted italic\">{c.adminComment || \"-\"}</td>\n                </tr>\n              ))}\n              {complaints.length === 0 && (\n                <tr>\n                  <td colSpan=\"5\" className=\"text-center py-4 text-muted\">No complaints raised yet.</td>\n                </tr>\n              )}\n            </tbody>\n          </Table>\n        </Card>\n      )}\n\n      {/* New Complaint Modal */}\n      <Modal show={showModal} onHide={() => setShowModal(false)} centered size=\"lg\">\n        <Modal.Header closeButton className=\"border-0\">\n          <Modal.Title className=\"font-weight-bold\">Raise New Complaint</Modal.Title>\n        </Modal.Header>\n        <Modal.Body className=\"p-4\">\n          {errorCreate && <Message variant=\"danger\">{errorCreate}</Message>}\n          <Form onSubmit={submitHandler}>\n            <Row>\n              <Col md={6}>\n                <Form.Group controlId=\"title\" className=\"mb-3\">\n                  <Form.Label className=\"small font-weight-bold\">Complaint Title</Form.Label>\n                  <Form.Control\n                    type=\"text\"\n                    placeholder=\"e.g., Fan not working\"\n                    value={title}\n                    onChange={(e) => setTitle(e.target.value)}\n                    required\n                    className=\"premium-input\"\n                  />\n                </Form.Group>\n              </Col>\n              <Col md={6}>\n                <Form.Group controlId=\"category\" className=\"mb-3\">\n                  <Form.Label className=\"small font-weight-bold\">Category</Form.Label>\n                  <Form.Control\n                    as=\"select\"\n                    value={category}\n                    onChange={(e) => setCategory(e.target.value)}\n                    className=\"premium-input\"\n                  >\n                    <option value=\"Electrical\">Electrical</option>\n                    <option value=\"Plumbing\">Plumbing</option>\n                    <option value=\"Furniture\">Furniture</option>\n                    <option value=\"Cleaning\">Cleaning</option>\n                    <option value=\"Other\">Other</option>\n                  </Form.Control>\n                </Form.Group>\n              </Col>\n            </Row>\n\n            <Row>\n              <Col md={6}>\n                <Form.Group controlId=\"roomNo\" className=\"mb-3\">\n                  <Form.Label className=\"small font-weight-bold\">Room Number</Form.Label>\n                  <Form.Control\n                    type=\"text\"\n                    placeholder=\"e.g., 204\"\n                    value={roomNo}\n                    onChange={(e) => setRoomNo(e.target.value)}\n                    required\n                    className=\"premium-input\"\n                  />\n                </Form.Group>\n              </Col>\n              <Col md={6}>\n                <Form.Group controlId=\"image\" className=\"mb-3\">\n                  <Form.Label className=\"small font-weight-bold\">Image URL (Optional)</Form.Label>\n                  <Form.Control\n                    type=\"text\"\n                    placeholder=\"Link to photo of issue\"\n                    value={image}\n                    onChange={(e) => setImage(e.target.value)}\n                    className=\"premium-input\"\n                  />\n                </Form.Group>\n              </Col>\n            </Row>\n\n            <Form.Group controlId=\"description\" className=\"mb-4\">\n              <Form.Label className=\"small font-weight-bold\">Detailed Description</Form.Label>\n              <Form.Control\n                as=\"textarea\"\n                rows={4}\n                placeholder=\"Explain the issue in detail...\"\n                value={description}\n                onChange={(e) => setDescription(e.target.value)}\n                required\n                className=\"premium-input\"\n              />\n            </Form.Group>\n\n            <Button type=\"submit\" variant=\"primary\" className=\"w-100 rounded-pill py-2 font-weight-bold shadow-sm\" disabled={loadingCreate}>\n              {loadingCreate ? \"Submitting...\" : \"Submit Ticket\"}\n            </Button>\n          </Form>\n        </Modal.Body>\n      </Modal>\n    </Container>\n  );\n};\n\nexport default ComplaintScreen;\n","C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\screens\\ComplaintAdminScreen.jsx",["248","249"],"import React, { useState, useEffect } from \"react\";\nimport { Container, Row, Col, Table, Card, Badge, Button, Modal, Form } from \"react-bootstrap\";\nimport { useDispatch, useSelector } from \"react-redux\";\nimport { listAllComplaints, updateComplaintStatus } from \"../actions/complaintActions.jsx\";\nimport { COMPLAINT_UPDATE_RESET } from \"../constants/complaintConstants.jsx\";\nimport Message from \"../components/message\";\nimport Loader from \"../components/loader\";\n\nconst ComplaintAdminScreen = () => {\n  const [showModal, setShowModal] = useState(false);\n  const [selectedComplaint, setSelectedComplaint] = useState(null);\n  const [status, setStatus] = useState(\"In Progress\");\n  const [adminComment, setAdminComment] = useState(\"\");\n\n  const dispatch = useDispatch();\n\n  const complaintAllList = useSelector((state) => state.complaintAllList);\n  const { loading, error, complaints } = complaintAllList;\n\n  const complaintUpdate = useSelector((state) => state.complaintUpdate);\n  const { loading: loadingUpdate, error: errorUpdate, success: successUpdate } = complaintUpdate;\n\n  useEffect(() => {\n    if (successUpdate) {\n      setShowModal(false);\n      setAdminComment(\"\");\n      dispatch({ type: COMPLAINT_UPDATE_RESET });\n      dispatch(listAllComplaints());\n    } else {\n      dispatch(listAllComplaints());\n    }\n  }, [dispatch, successUpdate]);\n\n  const openModal = (complaint) => {\n    setSelectedComplaint(complaint);\n    setStatus(complaint.status);\n    setAdminComment(complaint.adminComment || \"\");\n    setShowModal(true);\n  };\n\n  const submitHandler = (e) => {\n    e.preventDefault();\n    dispatch(updateComplaintStatus(selectedComplaint._id, status, adminComment));\n  };\n\n  return (\n    <Container className=\"py-4\">\n      <h2 className=\"font-weight-bold mb-4 text-dark\">Manage Complaints & Maintenance</h2>\n\n      {loading ? (\n        <Loader />\n      ) : error ? (\n        <Message variant=\"danger\">{error}</Message>\n      ) : (\n        <Card className=\"border-0 shadow-sm rounded-lg overflow-hidden\">\n          <Table responsive hover className=\"mb-0\">\n            <thead className=\"bg-light\">\n              <tr>\n                <th>Student</th>\n                <th>Room</th>\n                <th>Title / Category</th>\n                <th>Status</th>\n                <th>Date</th>\n                <th>Actions</th>\n              </tr>\n            </thead>\n            <tbody>\n              {complaints.map((c) => (\n                <tr key={c._id}>\n                  <td>\n                    <div className=\"font-weight-bold\">{c.student?.name}</div>\n                    <div className=\"small text-muted\">{c.student?.email}</div>\n                  </td>\n                  <td><Badge variant=\"dark\" className=\"px-3\">{c.roomNo}</Badge></td>\n                  <td>\n                    <div className=\"font-weight-bold\">{c.title}</div>\n                    <Badge variant=\"light\" className=\"border small\">{c.category}</Badge>\n                  </td>\n                  <td>\n                    <Badge variant={c.status === \"Resolved\" ? \"success\" : c.status === \"Pending\" ? \"warning\" : \"info\"} pill className=\"px-3\">\n                      {c.status}\n                    </Badge>\n                  </td>\n                  <td className=\"small text-muted\">{new Date(c.createdAt).toLocaleDateString()}</td>\n                  <td>\n                    <Button variant=\"outline-primary\" size=\"sm\" className=\"rounded-pill px-3\" onClick={() => openModal(c)}>\n                      Update\n                    </Button>\n                  </td>\n                </tr>\n              ))}\n              {complaints.length === 0 && (\n                <tr>\n                  <td colSpan=\"6\" className=\"text-center py-4 text-muted italic\">No complaints found in the system.</td>\n                </tr>\n              )}\n            </tbody>\n          </Table>\n        </Card>\n      )}\n\n      {/* Update Modal */}\n      <Modal show={showModal} onHide={() => setShowModal(false)} centered>\n        <Modal.Header closeButton className=\"border-0\">\n          <Modal.Title className=\"font-weight-bold\">Update Complaint Status</Modal.Title>\n        </Modal.Header>\n        <Modal.Body className=\"p-4\">\n          {errorUpdate && <Message variant=\"danger\">{errorUpdate}</Message>}\n          {selectedComplaint && (\n            <div className=\"mb-4\">\n              <div className=\"bg-light p-3 rounded mb-3\">\n                <h6 className=\"font-weight-bold mb-1\">{selectedComplaint.title}</h6>\n                <p className=\"small text-muted mb-2\">{selectedComplaint.description}</p>\n                {selectedComplaint.image && (\n                    <a href={selectedComplaint.image} target=\"_blank\" rel=\"noopener noreferrer\" className=\"small text-primary font-weight-bold\">\n                        <i className=\"fas fa-image mr-1\"></i> View Photo Proof\n                    </a>\n                )}\n              </div>\n              \n              <Form onSubmit={submitHandler}>\n                <Form.Group controlId=\"status\" className=\"mb-3\">\n                  <Form.Label className=\"small font-weight-bold\">Status</Form.Label>\n                  <Form.Control\n                    as=\"select\"\n                    value={status}\n                    onChange={(e) => setStatus(e.target.value)}\n                    className=\"premium-input\"\n                  >\n                    <option value=\"Pending\">Pending</option>\n                    <option value=\"In Progress\">In Progress</option>\n                    <option value=\"Resolved\">Resolved</option>\n                  </Form.Control>\n                </Form.Group>\n\n                <Form.Group controlId=\"adminComment\" className=\"mb-4\">\n                  <Form.Label className=\"small font-weight-bold\">Admin Comment / Note</Form.Label>\n                  <Form.Control\n                    as=\"textarea\"\n                    rows={3}\n                    placeholder=\"Provide updates or resolution details...\"\n                    value={adminComment}\n                    onChange={(e) => setAdminComment(e.target.value)}\n                    className=\"premium-input\"\n                  />\n                </Form.Group>\n\n                <Button type=\"submit\" variant=\"primary\" className=\"w-100 rounded-pill py-2 font-weight-bold shadow-sm\" disabled={loadingUpdate}>\n                  {loadingUpdate ? \"Updating...\" : \"Save Changes\"}\n                </Button>\n              </Form>\n            </div>\n          )}\n        </Modal.Body>\n      </Modal>\n    </Container>\n  );\n};\n\nexport default ComplaintAdminScreen;\n","C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\actions\\complaintActions.jsx",[],{"ruleId":"250","replacedBy":"251"},{"ruleId":"252","replacedBy":"253"},{"ruleId":"254","severity":1,"message":"255","line":26,"column":11,"nodeType":"256","messageId":"257","endLine":26,"endColumn":19},{"ruleId":"254","severity":1,"message":"258","line":2,"column":21,"nodeType":"256","messageId":"257","endLine":2,"endColumn":24},{"ruleId":"254","severity":1,"message":"259","line":2,"column":26,"nodeType":"256","messageId":"257","endLine":2,"endColumn":29},"no-native-reassign",["260"],"no-negated-in-lhs",["261"],"no-unused-vars","'userInfo' is assigned a value but never used.","Identifier","unusedVar","'Row' is defined but never used.","'Col' is defined but never used.","no-global-assign","no-unsafe-negation"]