\\userReducers.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\reducers\\attendanceReducer.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\components\\message.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\components\\loader.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\components\\formContainer.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\screens\\studentTableView.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\components\\student.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\actions\\userActions.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\actions\\attendanceActions.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\components\\analysisComponent.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\components\\attendanceTable.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\components\\paginate.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\components\\searchBox.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\constants\\studentConstant.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\constants\\userConstants.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\constants\\attendanceConstant.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\components\\attendanceTableComponent.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\components\\protectedRoute.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\components\\scrollToTop.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\screens\\StaffDashboard.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\screens\\AdminDashboard.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\screens\\StudentDashboard.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\screens\\StaffManagementScreen.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\screens\\ApprovalScreen.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\components\\customToast.jsx",[],"C:\\Users\\dhruv\\Downloads\\Hostel-Management-main\\Hostel-Management-main\\frontend\\src\\screens\\MyAttendanceView.jsx",["183","184"],"import React, { useState, useEffect } from \"react\";\nimport { Link } from \"react-router-dom\";\nimport { Row, Col, Table, Card, Button, Badge, Container } from \"react-bootstrap\";\nimport { useSelector } from \"react-redux\";\nimport axios from \"axios\";\nimport Loader from \"../components/loader\";\nimport Message from \"../components/message\";\n\nconst MyAttendanceView = () => {\n  const [attendance, setAttendance] = useState([]);\n  const [loading, setLoading] = useState(true);\n  const [error, setError] = useState(null);\n  const [currentPage, setCurrentPage] = useState(1);\n  const recordsPerPage = 15;\n\n  const userLogin = useSelector((state) => state.userLogin);\n  const { userInfo } = userLogin;\n\n  useEffect(() => {\n    const fetchAttendance = async () => {\n      try {\n        setLoading(true);\n        const config = {\n          headers: {\n            Authorization: `Bearer ${userInfo.token}`,\n          },\n        };\n        \n        // Find student profile first\n        const { data: profiles } = await axios.get(\"/student/all\", config);\n        const myProfile = profiles.students.find(s => s.name === userInfo.name);\n\n        if (myProfile) {\n          const { data } = await axios.get(`/attendance/student/${myProfile._id}`, config);\n          setAttendance(data);\n        } else {\n          setError(\"Profile not found.\");\n        }\n        setLoading(false);\n      } catch (err) {\n        setError(err.message);\n        setLoading(false);\n      }\n    };\n\n    fetchAttendance();\n  }, [userInfo]);\n\n  // Pagination Logic\n  const indexOfLastRecord = currentPage * recordsPerPage;\n  const indexOfFirstRecord = indexOfLastRecord - recordsPerPage;\n  const currentRecords = attendance.slice(indexOfFirstRecord, indexOfLastRecord);\n  const totalPages = Math.ceil(attendance.length / recordsPerPage);\n\n  const paginate = (pageNumber) => setCurrentPage(pageNumber);\n\n  const formatDate = (dateStr) => {\n    if (!dateStr) return \"N/A\";\n    const [year, month, day] = dateStr.split(\"-\");\n    return `${day}/${month}/${year}`;\n  };\n\n  return (\n    <Container className=\"py-4 fade-in\">\n      <Link to=\"/\" className=\"btn btn-light shadow-sm rounded-pill px-3 mb-4\">\n        <i className=\"fas fa-arrow-left mr-2\"></i> Dashboard\n      </Link>\n\n      <div className=\"d-flex justify-content-between align-items-center mb-4\">\n        <h2 className=\"font-weight-bold text-primary mb-0\">My Attendance History</h2>\n        <Badge variant=\"info\" pill className=\"px-3 py-2\">\n           Total Records: {attendance.length}\n        </Badge>\n      </div>\n\n      {loading ? (\n        <Loader />\n      ) : error ? (\n        <Message variant=\"danger\">{error}</Message>\n      ) : (\n        <>\n          <Card className=\"border-0 shadow-sm rounded-lg overflow-hidden\">\n            <Card.Body className=\"p-0\">\n              <Table responsive hover className=\"mb-0 premium-table\">\n                <thead className=\"bg-light\">\n                  <tr>\n                    <th>#</th>\n                    <th>DATE</th>\n                    <th>STATUS</th>\n                    <th>MARKED BY</th>\n                    <th>REMARKS</th>\n                  </tr>\n                </thead>\n                <tbody>\n                  {currentRecords.map((record, index) => (\n                    <tr key={index}>\n                      <td className=\"text-muted small\">{indexOfFirstRecord + index + 1}</td>\n                      <td className=\"font-weight-bold text-dark\">{formatDate(record.date)}</td>\n                      <td>\n                        <Badge \n                          pill \n                          className=\"px-3 py-2\"\n                          style={{\n                            backgroundColor: \n                              record.status === \"Present\" ? \"#f0fff4\" : \n                              record.status === \"Leave\" ? \"#fffaf0\" : \"#fff5f5\",\n                            color: \n                              record.status === \"Present\" ? \"#38a169\" : \n                              record.status === \"Leave\" ? \"#b7791f\" : \"#e53e3e\",\n                            border: `1px solid ${\n                              record.status === \"Present\" ? \"#c6f6d5\" : \n                              record.status === \"Leave\" ? \"#fbd38d\" : \"#feb2b2\"\n                            }`\n                          }}\n                        >\n                          {record.status === \"Present\" ? \"In Hostel\" : \n                           record.status === \"Leave\" ? \"At Home\" : \"Outside\"}\n                        </Badge>\n                      </td>\n                      <td className=\"small text-secondary\">\n                        {record.markedBy ? record.markedBy.name : \"System\"}\n                      </td>\n                      <td className=\"small text-muted\">{record.remarks || \"-\"}</td>\n                    </tr>\n                  ))}\n                </tbody>\n              </Table>\n            </Card.Body>\n          </Card>\n\n          {/* Pagination Controls */}\n          {totalPages > 1 && (\n            <div className=\"d-flex justify-content-center align-items-center mt-5\">\n              <Button \n                variant=\"outline-primary\" \n                className=\"rounded-pill px-4 mx-2\"\n                onClick={() => paginate(currentPage - 1)}\n                disabled={currentPage === 1}\n              >\n                <i className=\"fas fa-chevron-left mr-2\"></i> Previous\n              </Button>\n              \n              <div className=\"mx-3 font-weight-bold\">\n                Page {currentPage} of {totalPages}\n              </div>\n\n              <Button \n                variant=\"outline-primary\" \n                className=\"rounded-pill px-4 mx-2\"\n                onClick={() => paginate(currentPage + 1)}\n                disabled={currentPage === totalPages}\n              >\n                Next <i className=\"fas fa-chevron-right ml-2\"></i>\n              </Button>\n            </div>\n          )}\n        </>\n      )}\n    </Container>\n  );\n};\n\nexport default MyAttendanceView;\n",{"ruleId":"185","replacedBy":"186"},{"ruleId":"187","replacedBy":"188"},{"ruleId":"189","severity":1,"message":"190","line":2,"column":34,"nodeType":"191","messageId":"192","endLine":2,"endColumn":38},{"ruleId":"189","severity":1,"message":"193","line":3,"column":10,"nodeType":"191","messageId":"192","endLine":3,"endColumn":13},{"ruleId":"189","severity":1,"message":"194","line":3,"column":15,"nodeType":"191","messageId":"192","endLine":3,"endColumn":18},"no-native-reassign",["195"],"no-negated-in-lhs",["196"],"no-unused-vars","'Card' is defined but never used.","Identifier","unusedVar","'Row' is defined but never used.","'Col' is defined but never used.","no-global-assign","no-unsafe-negation"]